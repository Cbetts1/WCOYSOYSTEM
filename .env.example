# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vaga:vagapassword@postgres:5432/vagadb
POSTGRES_USER=vaga
POSTGRES_PASSWORD=vagapassword
POSTGRES_DB=vagadb

# ─── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ─── Node ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Ports ──────────────────────────────────────────────────────────────────────
API_PORT=4000
WORKER_PORT=4001
FRONTEND_USER_PORT=3000
FRONTEND_ADMIN_PORT=3001

# ─── Internal API URL (used by frontends) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
